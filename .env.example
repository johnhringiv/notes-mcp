# Copy to .env next to docker-compose.yml on the NAS. Local dev only needs
# NOTES_REPO_PATH pointed at an existing clone.

# --- notes repo -------------------------------------------------------------
# Repo to clone at first startup (and pull/push thereafter). Required in the
# container; optional locally if NOTES_REPO_PATH already holds a working tree.
NOTES_REPO_URL=https://github.com/<you>/<your-notes-repo>.git
# Branch to track (default: main)
NOTES_REPO_BRANCH=main
# Where the working tree lives (default: /repo — the Docker volume)
#NOTES_REPO_PATH=/repo

# --- credentials ------------------------------------------------------------
# Fine-grained GitHub PAT (contents read/write, scoped to the notes repo
# only). Never embedded in the git remote URL. Either the value directly or
# a _FILE path to it (direct value wins).
GITHUB_TOKEN=
#GITHUB_TOKEN_FILE=/run/secrets/github_token

# --- cloudflare tunnel (ingress only; no Access app in front of /mcp) --------
# Tunnel token for the cloudflared container (Zero Trust dashboard).
TUNNEL_TOKEN=

# --- oauth (server-side OAuth 2.1; GitHub is the upstream identity) ----------
# Setting PUBLIC_URL enables auth. It is the externally visible base URL and
# the OAuth issuer.
PUBLIC_URL=https://mcp.example.com
# GitHub OAuth app (Settings → Developer settings → OAuth Apps).
# Authorization callback URL must be: $PUBLIC_URL/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
#GITHUB_OAUTH_CLIENT_SECRET_FILE=/run/secrets/github_oauth_client_secret
# The only GitHub login allowed through (required when auth is enabled).
GITHUB_ALLOWED_LOGIN=
# Where the token signing secret + client registrations persist (default /data).
#OAUTH_STATE_DIR=/data

# --- server -----------------------------------------------------------------
# Bind address/port (Dockerfile sets 0.0.0.0:8000 in the container).
#MCP_HOST=127.0.0.1
#MCP_PORT=8000
#LOG_LEVEL=info

# --- git identity -----------------------------------------------------------
# Distinct author so the server's commits are greppable next to your own.
#GIT_AUTHOR_NAME=Claude MCP
#GIT_AUTHOR_EMAIL=claude-mcp@users.noreply.github.com

# --- script execution -------------------------------------------------------
#SCRIPT_TIMEOUT_DEFAULT=60
#SCRIPT_TIMEOUT_MAX=300

# --- deploy ------------------------------------------------------------------
# Image ref for deploy.sh to pull (CI publishes to GHCR on every push to main).
#IMAGE=ghcr.io/<you>/notes-mcp:latest
